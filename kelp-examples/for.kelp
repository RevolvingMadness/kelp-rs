use std::*

struct Container<T> {
    value: T
}

mcfn namespace:main {
    let containers = [
        Container::<string> {
            value: "a"
        },
        Container::<string> {
            value: "b"
        },
        Container::<string> {
            value: "c"
        },
        Container::<string> {
            value: "d"
        }
    ]

    for Container::<string> { value } in (containers) {
        tellraw @a value
    }
}